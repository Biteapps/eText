<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Нажатое состояние -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/gb_orange_dark"/>
            <corners android:radius="6dp"/>
            <stroke android:width="2dp" android:color="@color/gb_orange"/>
        </shape>
    </item>

    <!-- Обычное состояние с 3D эффектом -->
    <item>
        <layer-list>
            <!-- Тень/основание -->
            <item android:bottom="4dp">
                <shape>
                    <gradient
                        android:startColor="@color/gb_orange_light"
                        android:endColor="@color/gb_orange"
                        android:angle="270"/>
                    <corners android:radius="6dp"/>
                    <stroke android:width="1dp" android:color="#ffcc66"/>
                </shape>
            </item>
            <!-- Верхняя часть кнопки -->
            <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="4dp">
                <shape>
                    <gradient
                        android:startColor="#ffcc80"
                        android:endColor="@color/gb_orange"
                        android:angle="270"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>